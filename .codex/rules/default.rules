prefix_rule(pattern=["bun", "update"], decision="allow")
prefix_rule(pattern=["pnpm"], decision="allow")
prefix_rule(pattern=["mkdir", "-p", ".git/refs/heads/pranaygp/codex"], decision="allow")
prefix_rule(pattern=["git", "checkout", "-b"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "push", "-u", "origin"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "rebase"], decision="allow")
prefix_rule(pattern=["git", "rebase", "--continue"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["./bootstrap.sh", "--force"], decision="allow")
prefix_rule(pattern=["cp", "~/.codex/config.toml", ".codex/config.toml"], decision="allow")
prefix_rule(pattern=["cp", "~/.config/ghostty/config", ".config/ghostty/config"], decision="allow")
